# GKIM Opportunity Finder v2 - Environment Variables
# Copy this file to .env and fill in your values.
# Requirement 18.6: All credentials stored securely via environment variables.

# ─── Application ─────────────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# ─── PostgreSQL ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gkim_v2

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Apollo.io (B2B enrichment, contact discovery, intent signals) ──
APOLLO_API_KEY=your-apollo-api-key

# ─── Lemlist (multi-channel outreach sequences) ──────────────
LEMLIST_API_KEY=your-lemlist-api-key

# ─── Adzuna (job/opportunity discovery) ──────────────────────
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# ─── Google / Gmail (email sending, calendar) ────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# ─── LLM Providers ──────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ─── LLM Configuration ──────────────────────────────────────
LLM_DEFAULT_PROVIDER=anthropic
LLM_MATCHING_MODEL=claude-sonnet-4-20250514
LLM_GENERATION_MODEL=claude-sonnet-4-20250514

# ─── Schema ─────────────────────────────────────────────────
SCHEMA_PATH=config/schema.yaml

# ─── Worker Settings ─────────────────────────────────────────
WORKER_ENRICHMENT_INTERVAL=3600
WORKER_POLLING_INTERVAL=300
WORKER_ANALYTICS_CRON=0 2 * * *
